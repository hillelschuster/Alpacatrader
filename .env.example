# =============================================================
# Alpacatrader v0.4.0 — Rebuild: Attention-First Top-Gainer Bot
# =============================================================
# Copy this file to .env and fill in your settings.
# .env is git-ignored. NEVER commit real secrets.

# --- Trading Mode ---
TRADING_MODE=paper
TRADING_LIVE_TRADING_CONFIRMED=no

# --- Alpaca Market Data (paper-mode enrichment only) ---
# Option A: Modern convention (recommended)
# ALPACA_API_KEY=your_key_here
# ALPACA_SECRET_KEY=your_secret_here
#
# Option B: Legacy APCA convention (also accepted)
# APCA_API_KEY_ID=your_key_here
# APCA_API_SECRET_KEY=your_secret_here
#
# These keys are used ONLY for quote/bar data enrichment in paper mode.
# Paper mode does NOT place live broker orders — it uses the local
# PaperExecutionGateway for all simulated fills.

# --- Config ---
# ALPACATRADER_CONFIG=config/custom.yaml  # Custom config file path
LOGGING_LEVEL=INFO
LOGGING_DIR=./logs
